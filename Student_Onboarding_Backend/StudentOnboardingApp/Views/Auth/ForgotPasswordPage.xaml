<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentOnboardingApp.ViewModels.Auth"
             x:Class="StudentOnboardingApp.Views.Auth.ForgotPasswordPage"
             x:DataType="vm:ForgotPasswordViewModel"
             Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource GradientStart}" Offset="0.0" />
            <GradientStop Color="{StaticResource GradientMid}" Offset="0.4" />
            <GradientStop Color="{StaticResource GradientEnd}" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Spacing="14" Padding="24" VerticalOptions="Center">

            <Border BackgroundColor="#FFFFFF88" StrokeThickness="0"
                    StrokeShape="RoundRectangle 22" HeightRequest="60" WidthRequest="60"
                    HorizontalOptions="Center" Margin="0,20,0,0">
                <Label Text="&#x1F512;" FontSize="28"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <Label Text="Forgot Password"
                   FontSize="26" FontFamily="OpenSansSemibold" FontAttributes="Bold"
                   TextColor="{StaticResource DarkText}" HorizontalOptions="Center" />
            <Label Text="Enter your email and we'll send you an OTP to reset your password"
                   FontSize="14" TextColor="{StaticResource TextSecondary}"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="0,0,0,8" />

            <Border BackgroundColor="#E8FFFFFF"
                    StrokeShape="RoundRectangle 24" Stroke="#60FFFFFF"
                    StrokeThickness="1" Padding="24,28">
                <Border.Shadow>
                    <Shadow Brush="#205B5BD6" Offset="0,8" Radius="32" Opacity="0.2" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="18">

                    <Border BackgroundColor="{StaticResource ErrorLight}"
                            StrokeShape="RoundRectangle 10" Stroke="{StaticResource ErrorRed}"
                            StrokeThickness="1" Padding="12,8"
                            IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}">
                        <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource ErrorText}"
                               FontSize="13" HorizontalTextAlignment="Center" />
                    </Border>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="EMAIL ADDRESS" FontSize="11" FontFamily="OpenSansSemibold"
                               TextColor="Black" CharacterSpacing="1" />
                        <Border BackgroundColor="White" Stroke="{StaticResource BorderColor}"
                                StrokeShape="RoundRectangle 12" Padding="14,2" StrokeThickness="1.5">
                            <Entry Placeholder="Enter your email" Text="{Binding Email}"
                                   Keyboard="Email" ReturnType="Done"
                                   TextColor="Black" PlaceholderColor="{StaticResource TextMuted}" />
                        </Border>
                    </VerticalStackLayout>

                    <Button Text="Send OTP"
                            Command="{Binding SendResetOtpCommand}"
                            BackgroundColor="{StaticResource Primary}" TextColor="White"
                            FontAttributes="Bold" FontFamily="OpenSansSemibold"
                            CornerRadius="14" HeightRequest="52" FontSize="16"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource Primary}" HorizontalOptions="Center" />

                    <Label Text="Back to Login"
                           TextColor="{StaticResource Primary}" FontAttributes="Bold"
                           FontFamily="OpenSansSemibold" FontSize="14"
                           TextDecorations="Underline" HorizontalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                        </Label.GestureRecognizers>
                    </Label>

                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
