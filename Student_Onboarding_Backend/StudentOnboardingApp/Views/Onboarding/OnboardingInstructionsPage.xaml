<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentOnboardingApp.ViewModels.Onboarding"
             xmlns:models="clr-namespace:StudentOnboardingApp.Models.Onboarding"
             x:Class="StudentOnboardingApp.Views.Onboarding.OnboardingInstructionsPage"
             x:DataType="vm:OnboardingInstructionsViewModel"
             Title="Onboarding"
             BackgroundColor="{StaticResource LightBackground}">

    <Grid RowDefinitions="*, Auto" Padding="20">

        <!-- Instructions List -->
        <CollectionView ItemsSource="{Binding Instructions}" Grid.Row="0">
            <CollectionView.Header>
                <VerticalStackLayout Spacing="6" Padding="0,10,0,20">
                    <Label Text="Welcome!"
                           FontSize="26"
                           FontFamily="OpenSansSemibold"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}" />
                    <Label Text="Please read the onboarding instructions carefully before proceeding."
                           FontSize="14"
                           TextColor="{StaticResource TextMuted}" />
                </VerticalStackLayout>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:OnboardingInstructionDto">
                    <Border BackgroundColor="White"
                            StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource BorderColor}"
                            Padding="18"
                            Margin="0,0,0,12"
                            StrokeThickness="1">
                        <Border.Shadow>
                            <Shadow Brush="#0A5B5BD6" Offset="0,2" Radius="10" Opacity="0.06" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="12">
                                <Border BackgroundColor="{StaticResource Primary}"
                                        StrokeShape="RoundRectangle 16"
                                        HeightRequest="34"
                                        WidthRequest="34"
                                        StrokeThickness="0">
                                    <Label Text="{Binding Order}"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           FontSize="14"
                                           FontFamily="OpenSansSemibold" />
                                </Border>
                                <Label Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="16"
                                       TextColor="{StaticResource DarkText}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding Content}"
                                   FontSize="14"
                                   TextColor="{StaticResource TextSecondary}"
                                   Padding="46,0,0,0"
                                   LineHeight="1.4" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Agree & Continue -->
        <Border Grid.Row="1" BackgroundColor="White"
                StrokeShape="RoundRectangle 16"
                Stroke="{StaticResource BorderColor}"
                Padding="16,14" StrokeThickness="1">
            <Border.Shadow>
                <Shadow Brush="#145B5BD6" Offset="0,-4" Radius="16" Opacity="0.1" />
            </Border.Shadow>
            <VerticalStackLayout Spacing="12">
                <HorizontalStackLayout Spacing="8">
                    <CheckBox IsChecked="{Binding IsAgreed}" Color="{StaticResource Primary}" />
                    <Label Text="I have read and agree to the onboarding instructions"
                           FontSize="14"
                           TextColor="{StaticResource DarkText}"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <Button Text="Continue"
                        Command="{Binding AcceptAndContinueCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        CornerRadius="12"
                        HeightRequest="50"
                        FontSize="16"
                        IsEnabled="{Binding IsAgreed}" />
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
