<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentOnboardingApp.ViewModels"
             xmlns:models="clr-namespace:StudentOnboardingApp.Models.Dashboard"
             x:Class="StudentOnboardingApp.Views.Dashboard.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Dashboard"
             BackgroundColor="{StaticResource LightBackground}">

    <Grid>
    <RefreshView IsRefreshing="{Binding IsRefreshing}"
                 Command="{Binding LoadDashboardCommand}"
                 RefreshColor="{StaticResource Primary}">
        <ScrollView>
            <VerticalStackLayout Spacing="0" Padding="20,48,20,32" x:Name="PageContent">

                <!-- Welcome Header Card -->
                <Border StrokeThickness="0" StrokeShape="RoundRectangle 20"
                        Padding="26,24" Margin="0,0,0,28"
                        x:Name="WelcomeCard">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                            <GradientStop Color="{StaticResource Secondary}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#405B5BD6" Offset="0,6" Radius="20" Opacity="0.3" />
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding Greeting}"
                                   FontSize="22" FontFamily="OpenSansSemibold"
                                   FontAttributes="Bold" TextColor="White" />
                            <Label Text="Track your enrollment and course details"
                                   FontSize="13" TextColor="#FFFFFFBB" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" BackgroundColor="#FFFFFF30"
                                StrokeThickness="0" StrokeShape="RoundRectangle 24"
                                HeightRequest="48" WidthRequest="48" VerticalOptions="Center">
                            <Label Text="&#x1F393;" FontSize="24"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Error -->
                <Border BackgroundColor="{StaticResource ErrorLight}"
                        StrokeShape="RoundRectangle 10" StrokeThickness="0" Padding="14,10"
                        Margin="0,0,0,16"
                        IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}">
                    <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource ErrorText}"
                           FontSize="13" HorizontalTextAlignment="Center" />
                </Border>

                <!-- Loading — with proper spacing -->
                <Border BackgroundColor="White" StrokeShape="RoundRectangle 16"
                        StrokeThickness="0" Padding="20" HorizontalOptions="Center"
                        Margin="0,0,0,20"
                        IsVisible="{Binding IsBusy}"
                        x:Name="LoadingCard">
                    <Border.Shadow>
                        <Shadow Brush="#145B5BD6" Offset="0,2" Radius="10" Opacity="0.1" />
                    </Border.Shadow>
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           Color="{StaticResource Primary}"
                                           HeightRequest="24" WidthRequest="24" />
                        <Label Text="Loading your dashboard..."
                               FontSize="13" TextColor="{StaticResource TextMuted}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- No Course Registered State -->
                <Border BackgroundColor="White"
                        StrokeShape="RoundRectangle 20"
                        Stroke="{StaticResource BorderColor}"
                        Padding="28,44" StrokeThickness="1"
                        Margin="0,8,0,0"
                        IsVisible="{Binding HasCourse, Converter={StaticResource InverseBoolConverter}}"
                        x:Name="NoCourseCard">
                    <Border.Shadow>
                        <Shadow Brush="#145B5BD6" Offset="0,4" Radius="20" Opacity="0.12" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                        <Border BackgroundColor="{StaticResource Surface3}"
                                StrokeThickness="0" StrokeShape="RoundRectangle 36"
                                HeightRequest="80" WidthRequest="80" HorizontalOptions="Center">
                            <Label Text="&#x1F4DA;" FontSize="36"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="No Registered Course"
                               FontSize="20" FontFamily="OpenSansSemibold"
                               FontAttributes="Bold" TextColor="{StaticResource DarkText}"
                               HorizontalOptions="Center" />
                        <Label Text="You haven't enrolled in any course yet. Browse our catalog to find the perfect course for you."
                               FontSize="14" TextColor="{StaticResource TextMuted}"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"
                               LineHeight="1.4" Margin="0,0,0,8" />
                        <Button Text="Browse Courses"
                                Command="{Binding GoToCoursesCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White" FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                CornerRadius="14" HeightRequest="52"
                                FontSize="16" Padding="32,0">
                            <Button.Shadow>
                                <Shadow Brush="#405B5BD6" Offset="0,4" Radius="14" Opacity="0.25" />
                            </Button.Shadow>
                        </Button>
                    </VerticalStackLayout>
                </Border>

                <!-- Course Card (when enrolled) -->
                <Border BackgroundColor="White"
                        StrokeShape="RoundRectangle 20"
                        Stroke="{StaticResource BorderColor}"
                        Padding="0" StrokeThickness="1"
                        Margin="0,8,0,0"
                        IsVisible="{Binding HasCourse}"
                        x:Name="CourseCard">
                    <Border.Shadow>
                        <Shadow Brush="#145B5BD6" Offset="0,4" Radius="20" Opacity="0.12" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="0">

                        <!-- Course Name Header -->
                        <Border StrokeThickness="0" StrokeShape="RoundRectangle 20,20,0,0" Padding="28,28">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                                    <GradientStop Color="{StaticResource Secondary}" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="ENROLLED COURSE" FontSize="10" FontFamily="OpenSansSemibold"
                                       TextColor="#FFFFFF99" CharacterSpacing="1.2" />
                                <Label Text="{Binding Dashboard.CourseName}"
                                       FontSize="24" FontAttributes="Bold"
                                       FontFamily="OpenSansSemibold" TextColor="White" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Details Grid -->
                        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto"
                              RowSpacing="1" ColumnSpacing="1"
                              BackgroundColor="{StaticResource BorderColor}">

                            <Border Grid.Row="0" Grid.Column="0"
                                    BackgroundColor="White" StrokeThickness="0" Padding="24,22">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="PAYMENT" FontSize="10" FontFamily="OpenSansSemibold"
                                           TextColor="{StaticResource TextMuted}" CharacterSpacing="0.8" />
                                    <Label Text="{Binding Dashboard.PaymentStatus}"
                                           FontSize="20" FontAttributes="Bold"
                                           FontFamily="OpenSansSemibold" TextColor="{StaticResource DarkText}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="1"
                                    BackgroundColor="White" StrokeThickness="0" Padding="24,22">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="DURATION" FontSize="10" FontFamily="OpenSansSemibold"
                                           TextColor="{StaticResource TextMuted}" CharacterSpacing="0.8" />
                                    <Label Text="{Binding Dashboard.CourseDuration}"
                                           FontSize="20" FontAttributes="Bold"
                                           FontFamily="OpenSansSemibold" TextColor="{StaticResource DarkText}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0"
                                    BackgroundColor="{StaticResource Surface3}" StrokeThickness="0" Padding="24,22">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="COURSE STATUS" FontSize="10" FontFamily="OpenSansSemibold"
                                           TextColor="{StaticResource TextMuted}" CharacterSpacing="0.8" />
                                    <Border BackgroundColor="{StaticResource SuccessLight}"
                                            StrokeThickness="0" StrokeShape="RoundRectangle 12"
                                            Padding="12,6" HorizontalOptions="Start">
                                        <Label Text="{Binding Dashboard.CourseStatus}"
                                               FontSize="14" FontAttributes="Bold"
                                               FontFamily="OpenSansSemibold" TextColor="{StaticResource SuccessText}" />
                                    </Border>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1"
                                    BackgroundColor="{StaticResource Surface3}" StrokeThickness="0" Padding="24,22">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="AMOUNT DUE" FontSize="10" FontFamily="OpenSansSemibold"
                                           TextColor="{StaticResource TextMuted}" CharacterSpacing="0.8" />
                                    <Label Text="{Binding Dashboard.AmountDue, StringFormat='Rs. {0:N0}'}"
                                           FontSize="18" FontAttributes="Bold"
                                           FontFamily="OpenSansSemibold" TextColor="{StaticResource DarkText}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <!-- Progress Bar Section -->
                        <Border BackgroundColor="White" StrokeThickness="0" Padding="28,24">
                            <VerticalStackLayout Spacing="14">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Text="COURSE PROGRESS" FontSize="10" FontFamily="OpenSansSemibold"
                                           TextColor="{StaticResource TextMuted}" CharacterSpacing="0.8"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1"
                                           Text="{Binding ProgressText}"
                                           FontSize="12" FontFamily="OpenSansSemibold"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="TextColor" Value="{StaticResource SuccessText}" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="False">
                                                <Setter Property="TextColor" Value="{StaticResource Primary}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>

                                <!-- Progress bar using MAUI ProgressBar -->
                                <ProgressBar x:Name="ProgressBarControl"
                                             Progress="0"
                                             ProgressColor="{StaticResource Primary}"
                                             HeightRequest="14"
                                             Margin="0,4" />

                                <!-- Percentage -->
                                <Label Text="{Binding CourseProgress, StringFormat='{0:P0}'}"
                                       FontSize="22" FontFamily="OpenSansSemibold"
                                       FontAttributes="Bold" HorizontalOptions="Center"
                                       Margin="0,4,0,0">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="True">
                                            <Setter Property="TextColor" Value="{StaticResource SuccessText}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="False">
                                            <Setter Property="TextColor" Value="{StaticResource Primary}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Enrolled Date Footer -->
                        <Border BackgroundColor="{StaticResource Surface3}"
                                StrokeThickness="0" StrokeShape="RoundRectangle 0,0,20,20" Padding="28,20">
                            <Label FontSize="13" TextColor="{StaticResource TextMuted}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Enrolled on: " />
                                        <Span Text="{Binding Dashboard.EnrolledDate, StringFormat='{0:MMM dd, yyyy}'}"
                                              FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- Completed Courses Section -->
                <Border BackgroundColor="White"
                        StrokeShape="RoundRectangle 20"
                        Stroke="{StaticResource BorderColor}"
                        Padding="0" StrokeThickness="1"
                        Margin="0,20,0,0"
                        IsVisible="{Binding HasCompletedCourses}">
                    <Border.Shadow>
                        <Shadow Brush="#145B5BD6" Offset="0,4" Radius="20" Opacity="0.12" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="0">
                        <!-- Section Header -->
                        <Border StrokeThickness="0" StrokeShape="RoundRectangle 20,20,0,0"
                                Padding="24,20" BackgroundColor="{StaticResource Surface2}">
                            <HorizontalStackLayout Spacing="10">
                                <Border BackgroundColor="{StaticResource SuccessLight}"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                        HeightRequest="36" WidthRequest="36">
                                    <Label Text="🏆" FontSize="18"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                    <Label Text="Completed Courses" FontSize="16"
                                           FontFamily="OpenSansSemibold" FontAttributes="Bold"
                                           TextColor="{StaticResource DarkText}" />
                                    <Label Text="Your learning achievements"
                                           FontSize="11" TextColor="{StaticResource TextMuted}" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>

                        <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" />

                        <!-- Completed Courses List -->
                        <CollectionView ItemsSource="{Binding CompletedCourses}"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:CompletedCourseDto">
                                    <VerticalStackLayout>
                                        <Grid Padding="24,16" ColumnDefinitions="Auto, *, Auto" ColumnSpacing="14">
                                            <!-- Checkmark icon -->
                                            <Border BackgroundColor="{StaticResource SuccessLight}"
                                                    StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                                    HeightRequest="40" WidthRequest="40"
                                                    VerticalOptions="Center">
                                                <Label Text="✅" FontSize="18"
                                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>

                                            <!-- Course info -->
                                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                                <Label Text="{Binding CourseName}"
                                                       FontSize="14" FontFamily="OpenSansSemibold"
                                                       FontAttributes="Bold" TextColor="{StaticResource DarkText}"
                                                       LineBreakMode="TailTruncation" MaxLines="1" />
                                                <Label FontSize="11" TextColor="{StaticResource TextMuted}">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="{Binding Duration}" />
                                                            <Span Text=" · Completed " />
                                                            <Span Text="{Binding CompletedAt, StringFormat='{0:MMM yyyy}'}" />
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                            </VerticalStackLayout>

                                            <!-- Completed badge -->
                                            <Border Grid.Column="2"
                                                    BackgroundColor="{StaticResource SuccessLight}"
                                                    StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                                    Padding="8,4" VerticalOptions="Center">
                                                <Label Text="Done" FontSize="10"
                                                       FontFamily="OpenSansSemibold" FontAttributes="Bold"
                                                       TextColor="{StaticResource SuccessText}" />
                                            </Border>
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="{StaticResource BorderLight}" Margin="24,0" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

    <!-- Floating Bot Avatar with Speech Bubble -->
    <VerticalStackLayout HorizontalOptions="End" VerticalOptions="End"
                         Margin="0,0,18,24" Spacing="8"
                         x:Name="BotContainer" ZIndex="100">
        <!-- Speech Bubble -->
        <Border x:Name="BotBubble"
                BackgroundColor="White"
                StrokeThickness="1" Stroke="{StaticResource BorderColor}"
                StrokeShape="RoundRectangle 14"
                Padding="14,10" HorizontalOptions="End"
                IsVisible="True" Opacity="0">
            <Border.Shadow>
                <Shadow Brush="#205B5BD6" Offset="0,3" Radius="12" Opacity="0.15" />
            </Border.Shadow>
            <Label x:Name="BotMessage"
                   Text="Hi there! Need help? Tap me!"
                   FontSize="13" FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource DarkText}"
                   MaximumWidthRequest="220" />
        </Border>

        <!-- Bot Avatar -->
        <Border x:Name="BotAvatar"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 30"
                HeightRequest="60" WidthRequest="60"
                HorizontalOptions="End">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                    <GradientStop Color="{StaticResource Secondary}" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="#605B5BD6" Offset="0,6" Radius="20" Opacity="0.5" />
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnFaqButtonTapped" />
            </Border.GestureRecognizers>
            <Label Text="&#x1F916;" FontSize="28"
                   HorizontalOptions="Center" VerticalOptions="Center" />
        </Border>
    </VerticalStackLayout>
    </Grid>
</ContentPage>
