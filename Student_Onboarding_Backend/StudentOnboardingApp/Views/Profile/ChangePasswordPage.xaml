<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentOnboardingApp.ViewModels"
             x:Class="StudentOnboardingApp.Views.Profile.ChangePasswordPage"
             x:DataType="vm:ChangePasswordViewModel"
             Title="Change Password"
             BackgroundColor="{StaticResource LightBackground}">

    <ScrollView>
        <VerticalStackLayout Spacing="18" Padding="20" VerticalOptions="Center">

            <Border BackgroundColor="{StaticResource Surface3}"
                    StrokeThickness="0" StrokeShape="RoundRectangle 28"
                    HeightRequest="56" WidthRequest="56" HorizontalOptions="Center">
                <Label Text="&#x1F512;" FontSize="24"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <Label Text="Change Password"
                   FontSize="24" FontFamily="OpenSansSemibold" FontAttributes="Bold"
                   TextColor="{StaticResource DarkText}" HorizontalOptions="Center" />

            <Border BackgroundColor="{StaticResource ErrorLight}"
                    StrokeShape="RoundRectangle 10" StrokeThickness="0" Padding="14,10"
                    IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}">
                <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource ErrorText}"
                       FontSize="13" HorizontalTextAlignment="Center" />
            </Border>

            <Border BackgroundColor="White" StrokeShape="RoundRectangle 20"
                    Stroke="{StaticResource BorderColor}" Padding="22" StrokeThickness="1">
                <Border.Shadow>
                    <Shadow Brush="#0A5B5BD6" Offset="0,2" Radius="12" Opacity="0.08" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="CURRENT PASSWORD" FontSize="11" FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextSecondary}" CharacterSpacing="1" />
                        <Border BackgroundColor="{StaticResource LightBackground}"
                                Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12"
                                Padding="14,2" StrokeThickness="1.5">
                            <Entry Placeholder="Enter current password" Text="{Binding CurrentPassword}"
                                   IsPassword="True" ReturnType="Next" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="NEW PASSWORD" FontSize="11" FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextSecondary}" CharacterSpacing="1" />
                        <Border BackgroundColor="{StaticResource LightBackground}"
                                Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12"
                                Padding="14,2" StrokeThickness="1.5">
                            <Entry Placeholder="Enter new password" Text="{Binding NewPassword}"
                                   IsPassword="True" ReturnType="Next" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="CONFIRM NEW PASSWORD" FontSize="11" FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextSecondary}" CharacterSpacing="1" />
                        <Border BackgroundColor="{StaticResource LightBackground}"
                                Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12"
                                Padding="14,2" StrokeThickness="1.5">
                            <Entry Placeholder="Confirm new password" Text="{Binding ConfirmNewPassword}"
                                   IsPassword="True" ReturnType="Done" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Button Text="Update Password"
                    Command="{Binding ChangePasswordCommand}"
                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                    FontAttributes="Bold" FontFamily="OpenSansSemibold"
                    CornerRadius="14" HeightRequest="52" FontSize="16"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
